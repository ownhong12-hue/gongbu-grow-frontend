{
  "functions": {
    "api/**/*.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/admin/stats", "destination": "/api/admin" },
    { "source": "/api/admin/reports", "destination": "/api/admin" },
    { "source": "/api/admin/quizzes/:id", "destination": "/api/admin" },
    { "source": "/api/admin/:path*", "destination": "/api/admin" },
    { "source": "/api/rivals/global", "destination": "/api/rivals/global" },
    { "source": "/api/rivals/school", "destination": "/api/rivals/school" },
    { "source": "/api/battle-rooms/join", "destination": "/api/battle-rooms" },
    { "source": "/api/battle-rooms/:id/answer", "destination": "/api/battle-rooms" },
    { "source": "/api/battle-rooms/:id/scores", "destination": "/api/battle-rooms" },
    { "source": "/api/battle-rooms/:id", "destination": "/api/battle-rooms" },
    { "source": "/api/:path*", "destination": "/api/:path*" }
  ]
}
